{
  "$schema": "https://json.schemastore.org/nest-cli",
  "collection": "@nestjs/schematics",
  "sourceRoot": "src",
  "compilerOptions": {
    "deleteOutDir": true,
    "plugins": ["@nestjs/swagger/plugin", "@nestjs/graphql/plugin"],
    "assets": [
      {
        "include": "/templates/**/*",
        "outDir": "dist"
      },
      {
        "include": "shared/i18n/translations/**/*",
        "outDir": "dist"
      }
    ],
    "watchAssets": true
  }
}
